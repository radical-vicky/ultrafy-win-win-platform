# Supabase Postgres
# DATABASE_URL: pooled (PgBouncer, port 6543) — used by the app at runtime.
#   pgbouncer=true tells Prisma to skip prepared statements (unsupported by
#   PgBouncer transaction mode); connection_limit=1 avoids exhausting the pool.
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL: direct connection (port 5432, no pooler) — used only by
#   `prisma migrate`, which needs a real connection to run DDL.
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# Only needed if you use the Supabase JS client directly (Storage, Realtime,
# Supabase Auth) somewhere — the app itself talks to Postgres via Prisma, so
# these three are optional for what's built so far.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Seed
SEED_ADMIN_EMAIL="[email protected]"
SEED_ADMIN_PASSWORD="changeme123"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Gmail SMTP (Nodemailer) — use a Google App Password
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
NOTIFY_TO_EMAIL="[email protected]"

# Auth
JWT_SECRET="replace-with-a-long-random-string"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# SMS OTP (optional — falls back to email-only if unset)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Rate limiting across multiple server instances (optional — falls back to in-memory if unset)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
